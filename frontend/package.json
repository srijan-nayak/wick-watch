{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "pretauri:dev": "bash ../scripts/ensure_sidecar.sh",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "setup:backend": "bash ../scripts/ensure_sidecar.sh && cd .. && python3 -m venv backend/.venv && backend/.venv/bin/pip install -q -r backend/requirements.txt && echo 'Backend venv ready'",
    "bundle:backend": "cd .. && bash scripts/bundle_backend.sh"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.10.1",
